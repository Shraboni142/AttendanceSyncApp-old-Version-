@model List<AttendanceSyncApp.Models.DTOs.ComplianceAction.ComplianceActionListDto>

@{
    ViewBag.Title = "Compliance List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    bool isReviewMode = ViewBag.IsReviewMode != null && Convert.ToBoolean(ViewBag.IsReviewMode);
}

<div class="container-fluid">
    <div class="card" style="margin-top:20px;">
        <div class="card-header">
            <div class="row">
                <div class="col-md-8">
                    <h3>@(isReviewMode ? "Employee Compliance Review" : "Compliance List")</h3>
                </div>
                <div class="col-md-4 text-right">
                    @if (!isReviewMode)
                    {
                        <a href="@Url.Action("Create", "AdminComplianceAction")" class="btn btn-success">Add New</a>
                    }
                </div>
            </div>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th>Compliance ID</th>
                            <th>Employee Code</th>
                            <th>Employee Name</th>
                            <th>Offence Type</th>
                            <th>Offence Details</th>
                            <th>Compliance Action Type</th>
                            <th>Compliance Action Details</th>
                            @if (isReviewMode)
                            {
                                <th>Status</th>
                            }
                            <th style="width:@(isReviewMode ? "220px" : "150px");">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.EmployeeCode</td>
                                    <td>@item.EmployeeName</td>
                                    <td>@item.OffenceType</td>
                                    <td>@item.OffenceDetails</td>
                                    <td>@item.ComplianceActionType</td>
                                    <td>@item.ComplianceActionDetails</td>

                                    @if (isReviewMode)
                                    {
                                        <td style="min-width:160px;">
                                            <select class="form-control reviewStatusDropdown" data-id="@item.Id">
                                                <option value="InProgress" @(item.ReviewStatus == "InProgress" ? "selected='selected'" : "")>InProgress</option>
                                                <option value="Resolve" @(item.ReviewStatus == "Resolve" ? "selected='selected'" : "")>Resolve</option>
                                                <option value="Reject" @(item.ReviewStatus == "Reject" ? "selected='selected'" : "")>Reject</option>
                                            </select>
                                        </td>
                                    }

                                    <td>
                                        @if (isReviewMode)
                                        {
                                            <a href="@Url.Action("ViewCompliance", "AdminComplianceAction", new { id = item.Id })" class="btn btn-info btn-sm">View</a>
                                            <a href="@Url.Action("Edit", "AdminComplianceAction", new { id = item.Id })" class="btn btn-primary btn-sm">Edit</a>
                                        }
                                        else
                                        {
                                            <a href="@Url.Action("Edit", "AdminComplianceAction", new { id = item.Id })" class="btn btn-primary btn-sm">Edit</a>
                                            <button type="button" class="btn btn-danger btn-sm btnDeleteComplianceAction" data-id="@item.Id">Delete</button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="@(isReviewMode ? 9 : 8)" class="text-center">No data found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/Scripts/Admin/ComplianceAction.js"></script>
}