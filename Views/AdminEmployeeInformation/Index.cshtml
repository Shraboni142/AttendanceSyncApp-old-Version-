@{
    ViewBag.Title = "Employee Information";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <input type="hidden" id="EmployeeDbId" />
    <input type="hidden" id="GeneralInfoId" />
    <h2>Employee Information</h2>
    <hr />

    <div class="card mb-4">
        <div class="card-header">
            <h4 class="mb-0">General</h4>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6">
                    <label for="EmployeeName">Employee Name</label>
                    <input type="text" id="EmployeeName" class="form-control" placeholder="Type Employee Name" />
                </div>
                <div class="col-md-6">
                    <label for="EmployeeCode">Employee Code</label>
                    <input type="text" id="EmployeeCode" class="form-control" placeholder="Type Employee Code" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label for="DesignationName">Designation</label>
                    <select id="DesignationName" class="form-control">
                        <option value="">-- Select Designation --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="FatherName">Father Name</label>
                    <input type="text" id="FatherName" class="form-control" placeholder="Type Father Name" />
                </div>
                <div class="col-md-4">
                    <label for="MotherName">Mother Name</label>
                    <input type="text" id="MotherName" class="form-control" placeholder="Type Mother Name" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label for="MobileNo">Mobile No</label>
                    <input type="text" id="MobileNo" class="form-control" placeholder="Type Mobile No" />
                </div>
                <div class="col-md-4">
                    <label for="DepartmentName">Department</label>
                    <select id="DepartmentName" class="form-control">
                        <option value="">-- Select Department --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="BranchName">Branch Name</label>
                    <input type="text" id="BranchName" class="form-control" placeholder="Type Branch Name" />
                </div>
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label for="BasicSalary">Basic Salary</label>
                    <input type="text" id="BasicSalary" class="form-control" placeholder="Type Salary" />
                </div>
                <div class="col-md-4">
                    <label for="DateOfBirth">Date of Birth</label>
                    <input type="date" id="DateOfBirth" class="form-control" />
                </div>

            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h4>Address</h4>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <h5>Present Address</h5>

                    <div class="mb-2">
                        <label for="PresentHouseVillageName">House/Village Name</label>
                        <input type="text" id="PresentHouseVillageName" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PresentHouseNo">House No.</label>
                        <input type="text" id="PresentHouseNo" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PresentRoadNo">Road No.</label>
                        <input type="text" id="PresentRoadNo" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PresentBlock">Block</label>
                        <input type="text" id="PresentBlock" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PresentArea">Area</label>
                        <input type="text" id="PresentArea" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PresentSector">Sector</label>
                        <input type="text" id="PresentSector" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PresentCountry">Country</label>
                        <input type="text" id="PresentCountry" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PresentDivision">Division</label>
                        <input type="text" id="PresentDivision" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PresentDistrict">District</label>
                        <input type="text" id="PresentDistrict" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PresentThanaUpazilla">Thana/Upazilla</label>
                        <input type="text" id="PresentThanaUpazilla" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PresentPostOffice">Post Office</label>
                        <input type="text" id="PresentPostOffice" class="form-control" />
                    </div>
                </div>

                <div class="col-md-6">
                    <h5>
                        Permanent Address
                        <input type="checkbox" id="SameAsPresent" />
                        <small>If Same to Present</small>
                    </h5>

                    <div class="mb-2">
                        <label for="PermanentHouseVillageName">House/Village Name</label>
                        <input type="text" id="PermanentHouseVillageName" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PermanentHouseNo">House No.</label>
                        <input type="text" id="PermanentHouseNo" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PermanentRoadNo">Road No.</label>
                        <input type="text" id="PermanentRoadNo" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PermanentBlock">Block</label>
                        <input type="text" id="PermanentBlock" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PermanentArea">Area</label>
                        <input type="text" id="PermanentArea" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PermanentSector">Sector</label>
                        <input type="text" id="PermanentSector" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PermanentCountry">Country</label>
                        <input type="text" id="PermanentCountry" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PermanentDivision">Division</label>
                        <input type="text" id="PermanentDivision" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PermanentDistrict">District</label>
                        <input type="text" id="PermanentDistrict" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PermanentThanaUpazilla">Thana/Upazilla</label>
                        <input type="text" id="PermanentThanaUpazilla" class="form-control" />
                    </div>

                    <div class="mb-2">
                        <label for="PermanentPostOffice">Post Office</label>
                        <input type="text" id="PermanentPostOffice" class="form-control" />
                    </div>
                </div>
            </div>


        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>Educational Background</h4>
            <button type="button" class="btn btn-success" id="btnAddEducationRow">
                Add Row
            </button>
        </div>
        <div class="card-body">
            <table class="table table-bordered" id="educationTable">
                <thead>
                    <tr>
                        <th>Education Name</th>
                        <th>Group</th>
                        <th>Board</th>
                        <th>Academic Year</th>
                        <th>Academic Institute</th>
                        <th>Division</th>
                        <th>Result</th>
                        <th style="width:180px;">Action</th>
                    </tr>
                </thead>
                <tbody></tbody>
            </table>

        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-12 text-end">
            <button type="button" id="btnSaveAllEmployeeInformation" class="btn btn-primary btn-lg">
                Save All Information
            </button>
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/Scripts/Admin/EmployeeInformation.js?v=2"></script>
}