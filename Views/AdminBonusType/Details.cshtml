@model AttendanceSyncApp.Models.DTOs.Payroll.BonusTypeDto

@{
    ViewBag.Title = "Bonus Type Details";
    ViewBag.ActiveMenu = "BonusType";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h3>Details of</h3>
<h2>@Model.BonusTypeName</h2>

<div class="card p-4" style="max-width:600px;">
    <table class="table table-borderless">
        <tr>
            <th style="width:200px;">Type Name</th>
            <td>@Model.BonusTypeName</td>
        </tr>
        <tr>
            <th>Remarks</th>
            <td>@Model.remark</td>
        </tr>
    </table>

    <div class="mt-3">
        <a href="@Url.Action("Edit", "AdminBonusType", new { id = Model.Id })" class="btn btn-primary">Edit</a>
        <a href="@Url.Action("Index", "AdminBonusType")" class="btn btn-secondary">Close</a>
    </div>
</div>