@using Microsoft.Reporting.WebForms
@using ReportViewerForMvc;

@{
    ViewBag.Title = "Employee Job Card Report";
    Layout = null;   // ✅ IMPORTANT (full screen এর জন্য)
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />

    <title>Employee Job Card Report</title>

    <style>
        html, body {
            width: 100%;
            min-height: 100%;
        }

        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            background: white;
        }

        #reportContainer {
            width: 100%;
            height: 100vh;
            display: flex;
            justify-content: center;
        }

            #reportContainer > * {
                margin-left: auto !important;
                margin-right: auto !important;
            }

            #reportContainer table {
                margin-left: auto !important;
                margin-right: auto !important;
            }

        iframe {
            width: 100% !important;
            height: 100vh !important;
            border: none;
        }
    </style>
</head>

<body>

    <div id="reportContainer">
        @Html.ReportViewer(ViewBag.ReportViewer as Microsoft.Reporting.WebForms.ReportViewer)
    </div>

</body>
</html>