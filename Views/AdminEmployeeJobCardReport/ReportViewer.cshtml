@using AttendanceSyncApp.Models.DTOs.Reports

@{
    var header = ViewBag.Header as EmployeeJobCardHeaderDto;
    var details = ViewBag.Details as List<EmployeeJobCardDetailDto>;
    var summary = ViewBag.Summary as EmployeeJobCardSummaryDto;
}

<div style="text-align:right; margin-bottom:10px;">
    <button onclick="history.back()"
            style="padding:6px 14px; background:#007bff; color:white; border:none; border-radius:4px;">
        ← Back
    </button>
</div>
<h2 style="margin-top:20px;">Employee Job Card Report</h2>

<style>
    .report-wrapper {
        font-family: Arial, Helvetica, sans-serif;
        font-size: 14px;
        color: #000;
    }

    .report-header {
        text-align: center;
        margin-bottom: 20px;
    }

        .report-header h3,
        .report-header h4,
        .report-header p {
            margin: 4px 0;
        }

    .info-box {
        border: 2px solid #444;
        padding: 10px;
        margin-bottom: 15px;
    }

    .info-table {
        width: 100%;
        border-collapse: collapse;
    }

        .info-table td {
            padding: 4px 8px;
            vertical-align: top;
        }

    .detail-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
    }

        .detail-table th,
        .detail-table td {
            border: 1px solid #999;
            padding: 6px 8px;
            text-align: center;
        }

        .detail-table th {
            background: #f2f2f2;
            font-weight: bold;
        }

    .absent {
        color: red;
        font-weight: bold;
    }

    .present {
        color: green;
        font-weight: bold;
    }

    .summary-title {
        margin-top: 15px;
        font-weight: bold;
    }

    .summary-box {
        border: 2px solid #444;
        padding: 10px;
        margin-top: 5px;
    }

    .summary-table {
        width: 100%;
        border-collapse: collapse;
    }

        .summary-table td {
            padding: 6px 10px;
            vertical-align: top;
        }
</style>

<div class="report-wrapper">
    <div class="report-header">
        <h3>@(header != null ? header.CompanyName : "")</h3>
        <p>@(header != null ? header.Address : "")</p>
        <p>
            Phone: @(header != null ? header.Phone : "")
            &nbsp;&nbsp; Fax: @(header != null ? header.Fax : "")
            &nbsp;&nbsp; Email: @(header != null ? header.Email : "")
        </p>
        <h4>Employee Job Card</h4>
        <p>
            From @(header != null ? header.FromDateText : "")
            to @(header != null ? header.ToDateText : "")
        </p>
    </div>

    <div class="info-box">
        <table class="info-table">
            <tr>
                <td><strong>Employee ID</strong></td>
                <td>:</td>
                <td>@(header != null ? header.EmployeeCode : "")</td>

                <td><strong>DOJ</strong></td>
                <td>:</td>
                <td>@(header != null ? header.DOJ : "")</td>
            </tr>
            <tr>
                <td><strong>Employee Name</strong></td>
                <td>:</td>
                <td>@(header != null ? header.EmployeeName : "")</td>

                <td><strong>Section</strong></td>
                <td>:</td>
                <td>@(header != null ? header.Section : "")</td>
            </tr>
            <tr>
                <td><strong>Designation</strong></td>
                <td>:</td>
                <td>@(header != null ? header.Designation : "")</td>

                <td><strong>Branch</strong></td>
                <td>:</td>
                <td>@(header != null ? header.Branch : "")</td>
            </tr>
            <tr>
                <td><strong>Department</strong></td>
                <td>:</td>
                <td>@(header != null ? header.Department : "")</td>

                <td><strong>Location</strong></td>
                <td>:</td>
                <td>@(header != null ? header.Location : "")</td>
            </tr>
        </table>
    </div>

    <table class="detail-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Shift</th>
                <th>In Time</th>
                <th>Out Time</th>
                <th>Late Minutes</th>
                <th>OT Hours</th>
                <th>Day Status</th>
                <th>Remarks</th>
            </tr>
        </thead>
        <tbody>
            @if (details != null && details.Count > 0)
            {
                foreach (var item in details)
                {
                    <tr>
                        <td>@item.Date</td>
                        <td>@item.Shift</td>
                        <td>@item.InTime</td>
                        <td>@item.OutTime</td>
                        <td>@item.LateMinutes</td>
                        <td>@item.OTHours</td>
                        <td class="@(item.DayStatus == "Absent" ? "absent" : "present")">@item.DayStatus</td>
                        <td>@item.Remarks</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8">No data found.</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="summary-title">Total Late Minutes and OT Hours :</div>

    <div class="summary-box">
        <table class="summary-table">
            <tr>
                <td><strong>Total Days</strong> : @(summary != null ? summary.TotalDays : 0)</td>
                <td><strong>Total Weekend Days</strong> : @(summary != null ? summary.TotalWeekendDays : 0)</td>
                <td><strong>Total Present Days</strong> : @(summary != null ? summary.TotalPresentDays : 0)</td>
            </tr>
            <tr>
                <td><strong>Total Working Days</strong> : @(summary != null ? summary.TotalWorkingDays : 0)</td>
                <td><strong>Total Absent Days</strong> : @(summary != null ? summary.TotalAbsentDays : 0)</td>
                <td><strong>Total Late Days</strong> : @(summary != null ? summary.TotalLateDays : 0)</td>
            </tr>
            <tr>
                <td><strong>Total Holidays</strong> : @(summary != null ? summary.TotalHolidays : 0)</td>
                <td><strong>Total Leave Days</strong> : @(summary != null ? summary.TotalLeaveDays : 0)</td>
                <td><strong>Total Attendance</strong> : @(summary != null ? summary.TotalAttendance : 0)</td>
            </tr>
        </table>
    </div>
</div>