@using Microsoft.Reporting.WebForms
@using ReportViewerForMvc;

@{
    ViewBag.Title = "Employee Job Card Report";
    Layout = null;   // ✅ IMPORTANT (full screen এর জন্য)
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />

    <title>Employee Job Card Report</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
        }

        #reportContainer {
            width: 100%;
            height: 100vh;
        }

        iframe {
            width: 100% !important;
            height: 100vh !important;
            border: none;
        }
    </style>
</head>

<body>

    <div id="reportContainer">
        @Html.ReportViewer(ViewBag.ReportViewer as Microsoft.Reporting.WebForms.ReportViewer)
    </div>

</body>
</html>