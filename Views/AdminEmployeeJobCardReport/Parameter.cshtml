@model List<AttendanceSyncApp.Models.DTOs.Reports.EmployeeDropdownDto>

<div style="text-align:right; margin-bottom:10px;">
    <button type="button" onclick="history.back()"
            style="padding:6px 14px; background:#007bff; color:white; border:none; border-radius:4px;">
        ← Back
    </button>
</div>

<h2>Employee Job Card</h2>

<form method="post" action="/AdminEmployeeJobCardReport/GenerateReport">
    <input type="hidden" name="ServerId" value="@ViewBag.ServerId" />
    <input type="hidden" name="DatabaseName" value="@ViewBag.DatabaseName" />

    <div style="margin-bottom:10px;">
        <label>From Date</label><br />
        <input type="date" name="FromDate" required />
    </div>

    <div style="margin-bottom:10px;">
        <label>To Date</label><br />
        <input type="date" name="ToDate" required />
    </div>

    <div style="margin-bottom:10px;">
        <label>Branch</label><br />
        <select id="BranchId" name="BranchId" required>
            <option value="">--Select--</option>
        </select>
    </div>

    <div style="margin-bottom:10px;">
        <label>Status</label><br />
        <select id="Status" name="Status" required>
            <option value="">--Select--</option>
            <option value="1">Active</option>
            <option value="0">Inactive</option>
        </select>
    </div>

    <p id="employeeCount">Total Employee: 0</p>

    <div style="margin-bottom:10px;">
        <label>Employee</label><br />
        <select id="EmployeeId" name="EmployeeId" required>
            <option value="">--- Select ---</option>
        </select>
    </div>

    <button type="submit">Generate Report</button>
</form>

<script src="~/Scripts/jquery-3.7.1.min.js"></script>
<script>
    $(document).ready(function () {
        var serverId = '@ViewBag.ServerId';
        var databaseName = '@ViewBag.DatabaseName';

        loadBranches();

        $('#BranchId, #Status').change(function () {
            loadEmployees();
        });

        function loadBranches() {
            $.ajax({
                url: '/AdminEmployeeJobCardReport/GetBranches',
                type: 'GET',
                data: {
                    serverId: serverId,
                    databaseName: databaseName
                },
                success: function (data) {
                    var branchDropdown = $('#BranchId');
                    branchDropdown.empty();
                    branchDropdown.append('<option value="">--Select--</option>');

                    $.each(data, function (i, item) {
                        branchDropdown.append('<option value="' + item.Id + '">' + item.BranchName + '</option>');
                    });
                },
                error: function () {
                    alert('Branch load failed.');
                }
            });
        }

        function loadEmployees() {
            var branchId = $('#BranchId').val();
            var status = $('#Status').val();

            var employeeDropdown = $('#EmployeeId');
            employeeDropdown.empty();
            employeeDropdown.append('<option value="">--- Select ---</option>');
            $('#employeeCount').text('Total Employee: 0');

            if (branchId === '' || status === '') {
                return;
            }

            $.ajax({
                url: '/AdminEmployeeJobCardReport/GetEmployeesByBranchAndStatus',
                type: 'GET',
                data: {
                    serverId: serverId,
                    databaseName: databaseName,
                    branchId: branchId,
                    status: status
                },
                success: function (data) {
                    $.each(data, function (i, item) {
                        employeeDropdown.append('<option value="' + item.Id + '">' + item.DisplayText + '</option>');
                    });

                    $('#employeeCount').text('Total Employee: ' + data.length);
                },
                error: function () {
                    alert('Employee load failed.');
                }
            });
        }
    });
</script>