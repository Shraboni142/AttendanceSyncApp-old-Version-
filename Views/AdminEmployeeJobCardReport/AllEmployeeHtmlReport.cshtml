@model AttendanceSyncApp.Models.DTOs.Reports.EmployeeJobCardAllReportViewDto
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Employee Job Card Report</title>
    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 14px;
            margin: 30px;
            color: #000;
        }

        .report-header {
            text-align: center;
            margin-bottom: 30px;
        }

            .report-header h2 {
                margin: 0 0 10px 0;
                font-size: 34px;
                font-weight: 700;
            }

            .report-header p {
                margin: 6px 0;
                font-size: 16px;
            }

        .date-range {
            margin-top: 10px;
            font-size: 16px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 25px;
        }

        th, td {
            border: 1px solid #bfbfbf;
            padding: 10px 8px;
            text-align: left;
            vertical-align: top;
        }

        th {
            background: #f2f2f2;
            font-weight: 700;
        }

        .text-center {
            text-align: center;
        }

        .no-data {
            margin-top: 20px;
            font-size: 16px;
            text-align: center;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="report-header">
        <h2>@Model.ReportTitle</h2>
        <p>@Model.CompanyName</p>
        <p>@Model.Address</p>
        <p>Phone: @Model.Phone, Fax: @Model.Fax, Email: @Model.Email</p>
        <p class="date-range">From @Model.FromDateText to @Model.ToDateText</p>
    </div>

    @if (Model.Rows != null && Model.Rows.Count > 0)
    {
        <table>
            <thead>
                <tr>
                    <th>Employee Name</th>
                    <th>Employee Code</th>
                    <th>Designation</th>
                    <th>Department</th>
                    <th class="text-center">Present</th>
                    <th class="text-center">Absent</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Rows)
                {
                    <tr>
                        <td>@item.EmployeeName</td>
                        <td>@item.EmployeeCode</td>
                        <td>@item.Designation</td>
                        <td>@item.Department</td>
                        <td class="text-center">@item.Present</td>
                        <td class="text-center">@item.Absent</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="no-data">No employee data found for the selected branch, status, and date range.</div>
    }
</body>
</html>