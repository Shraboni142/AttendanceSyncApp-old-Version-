@model List<AttendanceSyncApp.Models.DTOs.Reports.EmployeeStatusReportRowDto>

<h2 style="margin-top:20px;">Employee Status Report</h2>

<style>
    .report-table {
        border-collapse: collapse;
        width: 100%;
        margin-top: 20px;
        font-family: Arial, Helvetica, sans-serif;
        font-size: 14px;
    }

        .report-table th {
            background-color: #3f51b5;
            color: white;
            padding: 10px;
            text-align: center;
            border: 1px solid #ccc;
        }

        .report-table td {
            padding: 8px;
            border: 1px solid #ddd;
            text-align: center;
        }

        .report-table tr:nth-child(even) {
            background-color: #f7f7f7;
        }

        .report-table tr:hover {
            background-color: #eaeaea;
        }

    .salary {
        text-align: right;
        font-weight: bold;
    }
</style>

<table class="report-table">
    <thead>
        <tr>
            <th>Employee Id</th>
            <th>Employee Name</th>
            <th>Branch Code</th>
            <th>Branch Name</th>
            <th>Designation Name</th>
            <th>Basic Salary</th>
            <th>Email</th>
            <th>Mobile No</th>
            <th>Status</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.EmployeeId</td>
                <td>@item.EmployeeName</td>
                <td>@item.BranchCode</td>
                <td>@item.BranchName</td>
                <td>@item.DesignationName</td>
                <td class="salary">@String.Format("{0:N2}", item.BasicSalary)</td>
                <td>@item.Email</td>
                <td>@item.MobileNo</td>
                <td>@(item.IsActive ? "Active" : "Inactive")</td>
            </tr>
        }
    </tbody>
</table>